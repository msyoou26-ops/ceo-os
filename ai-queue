<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Queue管理（開発確認用） - AI編集部</title>
<style>
  :root{
    --bg-deep:#0d1420;
    --bg-card:#16213a;
    --bg-card-active:#1c2b4a;
    --bg-panel:#101a2c;
    --accent:#ff8c42;
    --accent-dim:rgba(255,140,66,0.14);
    --done:#34d399;
    --done-dim:rgba(52,211,153,0.14);
    --waiting:#3d4a63;
    --running:#3aa0ff;
    --running-dim:rgba(58,160,255,0.14);
    --failed:#ef4444;
    --failed-dim:rgba(239,68,68,0.14);
    --notstarted:#5b6c8c;
    --text-1:#f3f1ea;
    --text-2:#aebcd6;
    --text-3:#7c8db0;
    --border:rgba(255,255,255,0.07);
  }
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  html,body{
    background:var(--bg-deep);
    color:var(--text-1);
    font-family:'Noto Sans CJK JP','Hiragino Sans',sans-serif;
    -webkit-font-smoothing:antialiased;
  }
  button{ font-family:inherit; border:none; background:none; color:inherit; cursor:pointer; }

  .topbar{
    position:sticky; top:0; z-index:10;
    background:linear-gradient(180deg, var(--bg-deep) 75%, rgba(13,20,32,0.85));
    padding:16px 16px 14px;
    border-bottom:1px solid var(--border);
  }
  .topbar__title{ font-size:19px; font-weight:800; }
  .topbar__note{ font-size:12px; color:var(--text-3); margin-top:4px; }

  .summary-row{
    display:flex; gap:10px; padding:14px 16px; overflow-x:auto;
  }
  .summary-chip{
    flex:1; min-width:76px; background:var(--bg-card); border-radius:12px; padding:10px 12px;
    border:1px solid var(--border); text-align:center;
  }
  .summary-chip__num{ font-size:20px; font-weight:800; }
  .summary-chip__label{ font-size:11px; color:var(--text-3); margin-top:2px; }

  #body{ padding:0 16px 40px; }

  .queue-card{
    background:var(--bg-card); border-radius:14px; padding:14px; margin-bottom:12px;
    border:1px solid var(--border);
  }
  .queue-card__top{ display:flex; justify-content:space-between; align-items:flex-start; gap:8px; }
  .queue-card__title{ font-size:14px; font-weight:700; line-height:1.4; }
  .queue-card__role{ font-size:12.5px; color:var(--text-2); margin-top:2px; }
  .status-badge{
    flex-shrink:0; font-size:11.5px; font-weight:700; padding:4px 10px; border-radius:999px;
  }
  .status-badge.waiting{ background:var(--bg-panel); color:var(--text-2); }
  .status-badge.running{ background:var(--running-dim); color:var(--running); }
  .status-badge.completed{ background:var(--done-dim); color:var(--done); }
  .status-badge.failed{ background:var(--failed-dim); color:var(--failed); }

  .queue-card__meta{ font-size:11.5px; color:var(--text-3); margin-top:8px; line-height:1.6; }
  .queue-card__error{
    margin-top:8px; font-size:12px; color:var(--failed); background:var(--failed-dim);
    border-radius:8px; padding:8px 10px; white-space:pre-wrap;
  }
  .queue-card__input{
    margin-top:8px; font-size:12px; color:var(--text-2); background:var(--bg-panel);
    border-radius:8px; padding:8px 10px; white-space:pre-wrap; display:none;
  }
  .queue-card__input.open{ display:block; }

  .queue-card__actions{ display:flex; gap:8px; margin-top:10px; flex-wrap:wrap; }
  .qbtn{
    font-size:12.5px; font-weight:700; padding:8px 12px; border-radius:9px; flex:1; min-width:90px;
  }
  .qbtn.primary{ background:var(--accent); color:#0d1420; }
  .qbtn.secondary{ background:var(--bg-panel); color:var(--text-2); border:1px solid var(--border); }
  .qbtn.danger{ background:var(--failed-dim); color:var(--failed); }
  .qbtn:disabled{ opacity:0.5; }

  .empty{ text-align:center; padding:60px 20px; color:var(--text-3); }
  .empty .icon{ font-size:32px; margin-bottom:10px; }
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar__title">Queue管理（開発確認用）</div>
  <div class="topbar__note">Sprint16.2・API未接続のモック実行版。この画面は管理者向けです。</div>
</div>

<div class="summary-row" id="summaryRow"></div>
<div id="body">
  <div class="empty"><div class="icon">⏳</div>データを取得しています…</div>
</div>

<script>
const GAS_WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbzNaCJQm2wS4DLeDSFLxLGtCsX7O79MAdy0YDnvbE2tLl51Yyl1DTf-rXxK2JXhpCuJiA/exec';

function escapeHTML(str){
  return String(str == null ? '' : str)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function formatRelativeTime(iso){
  if(!iso) return '-';
  const d = new Date(iso);
  if(isNaN(d.getTime())) return '-';
  const diffMs = Date.now() - d.getTime();
  const mins = Math.floor(diffMs / 60000);
  if(mins < 1) return 'たった今';
  if(mins < 60) return mins + '分前';
  const hours = Math.floor(mins / 60);
  if(hours < 24) return hours + '時間前';
  return Math.floor(hours / 24) + '日前';
}

let currentItems = [];

function renderSummary(items){
  const counts = { waiting:0, running:0, completed:0, failed:0 };
  items.forEach(function(it){ if(counts[it.status] !== undefined) counts[it.status]++; });
  const el = document.getElementById('summaryRow');
  el.innerHTML = `
    <div class="summary-chip"><div class="summary-chip__num">${counts.waiting}</div><div class="summary-chip__label">待機中</div></div>
    <div class="summary-chip"><div class="summary-chip__num">${counts.running}</div><div class="summary-chip__label">実行中</div></div>
    <div class="summary-chip"><div class="summary-chip__num">${counts.completed}</div><div class="summary-chip__label">完了</div></div>
    <div class="summary-chip"><div class="summary-chip__num">${counts.failed}</div><div class="summary-chip__label">失敗</div></div>
  `;
}

function statusLabel(status){
  return { waiting:'待機中', running:'実行中', completed:'完了', failed:'失敗' }[status] || status;
}

function renderQueueCard(item){
  const canRun = item.status === 'waiting';
  const canRetry = item.status === 'failed' && Number(item.retryCount) < Number(item.maxRetries || 3);
  const canForceFail = item.status === 'waiting' || item.status === 'running';

  return `
    <div class="queue-card" data-queue-id="${item.queueId}">
      <div class="queue-card__top">
        <div>
          <div class="queue-card__title">${escapeHTML(item.contentTitle)}</div>
          <div class="queue-card__role">${escapeHTML(item.roleLabel)} ・ 優先度:${escapeHTML(item.priority || 'normal')}</div>
        </div>
        <span class="status-badge ${item.status}">${statusLabel(item.status)}</span>
      </div>
      <div class="queue-card__meta">
        作成:${formatRelativeTime(item.createdAt)} ・ 開始:${formatRelativeTime(item.startedAt)} ・ 終了:${formatRelativeTime(item.finishedAt)}<br>
        再試行:${item.retryCount || 0}/${item.maxRetries || 3} ・ queueId: ${escapeHTML(item.queueId)}
      </div>
      ${item.errorMessage ? `<div class="queue-card__error">⚠️ ${escapeHTML(item.errorMessage)}</div>` : ''}
      <div class="queue-card__input" id="input-${item.queueId}">${escapeHTML(item.input || '(inputなし)')}</div>
      <div class="queue-card__actions">
        <button class="qbtn primary" ${canRun ? '' : 'disabled'} onclick="runItem('${item.queueId}')">実行</button>
        <button class="qbtn secondary" ${canRetry ? '' : 'disabled'} onclick="retryItem('${item.queueId}')">再試行</button>
        <button class="qbtn secondary" onclick="toggleDetail('${item.queueId}')">詳細確認</button>
        <button class="qbtn danger" ${canForceFail ? '' : 'disabled'} onclick="forceFail('${item.queueId}')">失敗にする(テスト用)</button>
      </div>
    </div>
  `;
}

function toggleDetail(queueId){
  const el = document.getElementById('input-' + queueId);
  if(el) el.classList.toggle('open');
}

function renderBody(items){
  currentItems = items;
  renderSummary(items);
  const bodyEl = document.getElementById('body');
  if(!items.length){
    bodyEl.innerHTML = `<div class="empty"><div class="icon">📭</div>Queueはまだありません。</div>`;
    return;
  }
  bodyEl.innerHTML = items.map(renderQueueCard).join('');
}

async function loadQueue(){
  try{
    const res = await fetch(GAS_WEB_APP_URL + '?action=getQueueList');
    const json = await res.json();
    if(!json.success) throw new Error(json.error || '取得に失敗しました');
    renderBody(json.data.items || []);
  }catch(e){
    document.getElementById('body').innerHTML = `
      <div class="empty">
        <div class="icon">⚠️</div>
        読み込みに失敗しました: ${escapeHTML(e.message || e)}<br><br>
        <button class="qbtn primary" style="max-width:160px; margin:0 auto;" onclick="loadQueue()">もう一度読み込む</button>
      </div>`;
  }
}

async function postAction(action, payload){
  const res = await fetch(GAS_WEB_APP_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'text/plain' },
    body: JSON.stringify(Object.assign({ action: action }, payload))
  });
  const json = await res.json();
  const result = json && json.data ? json.data : null;
  if(!json.success || !result || result.success === false){
    throw new Error((result && result.message) || json.error || '処理に失敗しました');
  }
  return result;
}

async function runItem(queueId){
  const card = document.querySelector(`.queue-card[data-queue-id="${queueId}"]`);
  const btn = card ? card.querySelector('.qbtn.primary') : null;
  if(btn){ btn.disabled = true; btn.textContent = '実行中…'; }
  try{
    await postAction('runQueueItem', { queueId: queueId, executedBy: '手動実行(管理画面)' });
    await loadQueue();
  }catch(e){
    alert('実行に失敗しました: ' + (e.message || e));
    if(btn){ btn.disabled = false; btn.textContent = '実行'; }
  }
}

async function retryItem(queueId){
  try{
    await postAction('retryQueueItem', { queueId: queueId });
    await loadQueue();
  }catch(e){
    alert('再試行に失敗しました: ' + (e.message || e));
  }
}

async function forceFail(queueId){
  if(!confirm('このQueueをテスト用に「失敗」状態にします。よろしいですか？')) return;
  try{
    await postAction('forceFailQueueItem', { queueId: queueId, errorMessage: 'テスト用の疑似エラー（管理画面から手動実行）' });
    await loadQueue();
  }catch(e){
    alert('処理に失敗しました: ' + (e.message || e));
  }
}

loadQueue();
</script>
</body>
</html>
